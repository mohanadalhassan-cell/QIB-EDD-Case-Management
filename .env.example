# ============================================================================
# EDD_QIB SYSTEM CONFIGURATION - إعدادات نظام EDD/QIB
# ============================================================================

# ENVIRONMENT
NODE_ENV=development
APP_NAME=EDD_QIB
APP_VERSION=2.0.0

# ============================================================================
# SERVER CONFIGURATION
# ============================================================================
PORT=8585
HOST=127.0.0.1
# For Netlify deployment
API_BASE_URL=http://localhost:8585

# ============================================================================
# AUTHENTICATION & SECURITY
# ============================================================================
JWT_SECRET=edd-qib-secret-key-2024-change-in-production
JWT_EXPIRES_IN=8h
JWT_ALGORITHM=HS256
# For production - use strong random string
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=change-in-production-use-random-string

# ============================================================================
# CORS & ORIGIN CONFIGURATION
# ============================================================================
CORS_ORIGIN=*
CORS_CREDENTIALS=true
# For production, restrict to specific domains:
# CORS_ORIGIN=https://qib-edd.netlify.app,https://qib.example.com

# ============================================================================
# DATABASE CONFIGURATION (Future PostgreSQL)
# ============================================================================
# Currently using in-memory storage
# DB_TYPE=mongo|postgresql|mysql
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=edd_qib
# DB_USER=postgres
# DB_PASSWORD=change_in_production
# DB_POOL_SIZE=10
# DB_MAX_CONNECTIONS=30

# ============================================================================
# EMAIL CONFIGURATION (Future)
# ============================================================================
SMTP_ENABLED=false
SMTP_HOST=mail.qib.com.qa
SMTP_PORT=587
SMTP_SECURE=true
SMTP_USER=noreply@qib.com.qa
SMTP_PASSWORD=change_in_production
SMTP_FROM=EDD System <noreply@qib.com.qa>

# ============================================================================
# SMS CONFIGURATION (Future)
# ============================================================================
SMS_ENABLED=false
SMS_PROVIDER=vonage
SMS_API_KEY=change_in_production
SMS_API_SECRET=change_in_production
SMS_FROM=QIB-EDD

# ============================================================================
# LOGGING & MONITORING
# ============================================================================
LOG_LEVEL=info
LOG_FORMAT=json
LOG_FILE=logs/app.log
DEBUG=false
VERBOSE=false

# ============================================================================
# FEATURE FLAGS
# ============================================================================
FEATURE_NOTIFICATIONS=true
FEATURE_DOCUMENT_UPLOAD=true
FEATURE_CALL_CENTER=true
FEATURE_VIDEO_KYC=false
FEATURE_ADVANCED_SEARCH=true
FEATURE_EXPORT_REPORTS=true
FEATURE_DECISION_SUPPORT=true
FEATURE_AUDIT_LOGS=true

# ============================================================================
# API RATE LIMITING
# ============================================================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_SKIP_SUCCESSFUL=false

# ============================================================================
# DATA & STORAGE
# ============================================================================
# Sample data size (for demo)
SAMPLE_DATA_COUNT=120
USE_MOCK_DATA=true
STORAGE_TYPE=session
# For production: STORAGE_TYPE=database

# ============================================================================
# EXTERNAL INTEGRATIONS
# ============================================================================
# THIRD_PARTY_API_URL=https://api.thirdparty.com
# THIRD_PARTY_API_KEY=change_in_production
# SANDBOX_MODE=false

# ============================================================================
# ANALYTICS & TRACKING (Optional)
# ============================================================================
ANALYTICS_ENABLED=false
GOOGLE_ANALYTICS_ID=
SENTRY_DSN=

# ============================================================================
# DEPLOYMENT TARGETS
# ============================================================================
# For Netlify
NETLIFY_ENABLED=true
# For Docker
DOCKER_ENABLED=false
DOCKER_PORT=8585

# ============================================================================
# TIMEOUTS & LIMITS
# ============================================================================
REQUEST_TIMEOUT=30000
FILE_UPLOAD_MAX_SIZE=52428800
SESSION_TIMEOUT=3600000

# ============================================================================
# PRODUCTION SETTINGS
# ============================================================================
# These should be set differently for production
PRODUCTION=false
USE_HTTPS=false
SSL_CERT_PATH=/path/to/cert.pem
SSL_KEY_PATH=/path/to/key.pem

# ============================================================================
# NOTES
# ============================================================================
# 1. Copy this file to .env for development
# 2. For production, create separate .env.production file
# 3. Never commit actual secrets to git - use environment variables
# 4. On Netlify, set these via Build Settings → Environment Variables
# 5. Critical secrets to change in production:
#    - JWT_SECRET (must be random 32+ chars)
#    - ENCRYPTION_KEY (must be random 32+ chars)
#    - Database credentials (if using DB)
#    - Email/SMS credentials
#    - CORS_ORIGIN (restrict to your domain)


# Session & Authentication
SESSION_SECRET=session-secret-change-in-production
SESSION_MAX_AGE=28800000

# Audit & Compliance
ENABLE_AUDIT_LOG=true
AUDIT_LOG_RETENTION_DAYS=90

# Performance
CACHE_ENABLED=true
CACHE_TTL=3600

# External API Integration
# QCB_API_BASE_URL=https://api.qcb.gov.qa
# SANCTIONS_API_KEY=change_in_production
